{
  "appId": "com.wavesnow.snowote",
  "productName": "snowote",
  "asar": true,
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist"
  ],
  "publish": [
    {
      "provider": "github",
      "owner": "wavesnows",
      "repo": "snowote"
    }
  ],
  "mac": {
    "icon": "build/icon.icns",
    "artifactName": "${productName}_${version}.${ext}",
    "target": ["dmg", "zip"]
  },
  "win": {
    "artifactName": "${productName}_${version}.${ext}",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  }
}
